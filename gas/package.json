{
  "name": "attendance-gas",
  "version": "0.1.0",
  "private": true,
  "description": "Google Apps Script workspace managed with clasp and TypeScript",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -w -p tsconfig.json",
    "push": "npm run build && clasp push",
    "pull": "clasp pull",
    "open": "clasp open",
    "deploy": "npm run build && clasp deploy",
    "login": "clasp login"
  },
  "devDependencies": {
    "@google/clasp": "^3.0.6-alpha",
    "@types/google-apps-script": "^2.0.8",
    "typescript": "^5.9.3"
  }
}
